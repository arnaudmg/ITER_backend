{
  "kind": "collectionType",
  "collectionName": "glossary_terms",
  "info": {
    "singularName": "glossary-term",
    "pluralName": "glossary-terms",
    "displayName": "Glossary Term",
    "description": "Termes du glossaire"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "definition": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "relatedTerms": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::glossary-term.glossary-term"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
