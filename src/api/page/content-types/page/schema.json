{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Generic pages migrated from WordPress"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "legacyUrl": {
      "type": "string",
      "unique": true
    },
    "body": {
      "type": "richtext"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.hero",
        "blocks.rich-text",
        "blocks.image",
        "blocks.cta",
        "blocks.faq",
        "blocks.testimonial",
        "blocks.pricing-table",
        "blocks.logo-cloud",
        "blocks.stats",
        "blocks.form-embed"
      ]
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "migrationMeta": {
      "type": "json",
      "description": "Importer metadata (batchId, wpId, checksums, etc.)"
    }
  }
}
