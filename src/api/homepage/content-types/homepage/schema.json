{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage",
    "description": "Page d'accueil"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "heroTitle": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "heroSubtitle": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "heroCta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.cta-link"
    },
    "valuePropositions": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.value-prop"
    },
    "statistics": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.statistic"
    },
    "whyChooseItems": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.why-choose"
    },
    "featuredArticles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog-article.blog-article"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
